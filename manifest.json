{
  "manifest_version": 3,
  "name": "Forum Read Addon",
  "version": "0.2.1",
  "description": "Lee automáticamente los posts de un hilo vBulletin",
  "action": {
    "default_title": "Forum Read",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "images/icon/icons8-audio-book-48.png"
    }
  },
  "icons": {
    "48": "images/icon/icons8-audio-book-48.png"
  },
  "permissions": ["activeTab", "tabs", "contextMenus", "storage"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "toggle-read": {
      "suggested_key": {
        "default": "F8"
      },
      "description": "Iniciar o detener lectura del hilo"
    }
  }
}
